<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title><%= pageTitle || "Your Books" %></title>
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
<style>
.book-cover{
width:100%;
height:180px;
object-fit:cover;
}

.book-card{
transition:transform .2s ease-in-out;
}

.book-card:hover{
transform:translateY(-5px);
}

.search-filter{
display:flex;
align-items:center;
gap:16px;
margin-bottom:20px;
}

/* hover glow for Home button */

.nav-link{
transition:all .25s ease;
}

.nav-link:hover{
color:#ffffff;
text-shadow:0 0 8px rgba(255,255,255,0.9);
transform:translateY(-2px);
}
.suggestions{
position:absolute;
background:white;
border:1px solid #ccc;
width:100%;
z-index:1000;
}
.suggestion-item{
padding:8px;
cursor:pointer;
}
.suggestion-item:hover{
background:#eee;
}
</style>

</head>

<body data-logged-in="<%= !!isLoggedIn %>">

<nav class="navbar navbar-expand-lg navbar-dark bg-dark">

<div class="container d-flex align-items-center">

<% if (isLoggedIn) { %>

<div class="dropdown me-3">

<button class="btn btn-outline-light btn-sm dropdown-toggle"
data-bs-toggle="dropdown">

👤 <%= username %>

</button>

<ul class="dropdown-menu">

<li>
<a class="dropdown-item" href="/books">My Books</a>
</li>

<li>
<a class="dropdown-item" href="/books?showall=1">Browse Library</a>
</li>

<li>
<hr class="dropdown-divider">
</li>

<li>
<a class="dropdown-item text-danger" href="/logout">Logout</a>
</li>

</ul>

</div>

<% } %>

<a class="nav-link text-white me-3" href="/">Home</a>


<form class="mx-auto d-flex"
action="/books/search"
method="GET"
style="max-width:520px;width:50%">

<div style="position:relative;width:100%">

<input
id="searchBox"
name="q"
class="form-control form-control-sm me-2"
type="search"
placeholder="Search books or authors"
autocomplete="off"
value="<%= typeof q !== 'undefined' ? q : '' %>">

<div id="suggestions" class="suggestions"></div>

</div>

<button class="btn btn-sm btn-success">
Search
</button>

</form>

<div class="d-flex align-items-center gap-3">

<% if (!isLoggedIn) { %>
<a href="/signin" class="btn btn-outline-light btn-sm">Login</a>
<% } %>

<div class="d-flex align-items-center">
🛒
<span id="cartCount"
class="badge bg-warning text-dark ms-1"
data-server-count="<%= typeof cartCount !== 'undefined' ? cartCount : 0 %>">
0
</span>
</div>

<a href="/checkout" class="btn btn-success btn-sm ms-2">Checkout</a>

</div>

</div>

</nav>


<div class="container mt-4">

<div class="row">

<div id="mainCol" class="col-md-12">

<% if (message) { %>

<div class="alert alert-success alert-dismissible fade show">

<%= message %>

<button class="btn-close" data-bs-dismiss="alert"></button>

</div>

<% } %>


<div class="search-filter">

<h2>
📚 <%= showAll ? "Library" : "Your Books" %>
</h2>

<div style="margin-left:auto"></div>

</div>


<div class="row" id="booksGrid">

<% if (books && books.length > 0) { %>

<% books.forEach(book => { %>

<div class="col-sm-6 col-md-4 col-lg-3 mb-4">

<div class="card book-card">

<img
src="<%= book.cover_image_url || '/images/default-cover.png' %>"
class="book-cover">

<div class="card-body">

<h5 class="card-title"><%= book.title %></h5>

<p class="card-text">

<strong>Author:</strong>
<%= book.author || 'N/A' %>

<br>

<small class="text-muted">
Book No: <%= book.book_no %>
</small>

</p>

<div class="d-flex gap-2">

<a
href="/read/<%= book.id %>"
target="_blank"
class="btn btn-primary btn-sm">
Read
</a>

<% if (!purchasedIds.includes(book.id)) { %>

<button
class="btn btn-success btn-sm add-to-cart-btn"
data-id="<%= book.id %>"
data-title="<%= book.title %>">
Add
</button>

<% } else { %>

<span class="badge bg-success align-self-center">
Purchased
</span>

<% } %>

</div>

</div>

</div>

</div>

<% }) %>

<% } else { %>

<div class="alert alert-info text-center">

<h5>No books purchased yet 📚</h5>

<p>You haven't bought any books.</p>

<a href="/books?showall=1" class="btn btn-primary btn-sm">
Browse Library
</a>

</div>

<% } %>

</div>

</div>

</div>

</div>


<!-- ✅ TOAST UI ADDED -->
<div class="position-fixed top-0 end-0 p-3" style="z-index: 9999">
  <div id="liveToast" class="toast align-items-center text-bg-success border-0" role="alert">
    <div class="d-flex">
      <div class="toast-body" id="toastMsg">
        Message here
      </div>
      <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
    </div>
  </div>
</div>


<script>

function showToast(message, isError = false) {
  const toastEl = document.getElementById("liveToast");
  const toastMsg = document.getElementById("toastMsg");

  toastMsg.innerText = message;

  toastEl.classList.remove("text-bg-success", "text-bg-danger");
  toastEl.classList.add(isError ? "text-bg-danger" : "text-bg-success");

  const toast = new bootstrap.Toast(toastEl);
  toast.show();
}

const CLIENT_LOGGED_IN = document.body.dataset.loggedIn === "true";

const badge = document.getElementById("cartCount");
const serverCount = parseInt(badge.dataset.serverCount || "0");

badge.innerText = serverCount;

document.querySelectorAll(".add-to-cart-btn").forEach(btn => {

btn.addEventListener("click", async () => {

const id = btn.getAttribute("data-id");
const title = btn.getAttribute("data-title");

try{

const res = await fetch("/cart/add",{
method:"POST",
credentials:"include",
headers:{ "Content-Type":"application/json" },
body:JSON.stringify({ id,title })
});

if(res.status === 401){

showToast("Please sign in first", true);
window.location.href="/signin";
return;

}

if(res.ok){

const data = await res.json();
badge.innerText = data.count;

showToast(title+" added to cart");

}

}catch(err){

console.error(err);

}

});

});

</script>

<script>
const searchBox=document.getElementById("searchBox");
const suggestions=document.getElementById("suggestions");

searchBox.addEventListener("keyup",async()=>{

const query=searchBox.value.trim();

if(query.length===0){
suggestions.innerHTML="";
return;
}

try{

const res=await fetch(`/search-suggest?q=${query}`);
const books=await res.json();

suggestions.innerHTML="";

if(books.length===0){
suggestions.innerHTML="<div class='suggestion-item'>No results</div>";
return;
}

books.forEach(book=>{

const div=document.createElement("div");
div.classList.add("suggestion-item");
div.innerText=book.title;

div.onclick=()=>{
searchBox.value=book.title;
suggestions.innerHTML="";
};

suggestions.appendChild(div);

});

}catch(err){
console.error("Search error",err);
}

});

document.addEventListener("click",function(e){

if(!searchBox.contains(e.target) && !suggestions.contains(e.target)){
suggestions.innerHTML="";
}

});

</script>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>