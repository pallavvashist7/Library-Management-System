<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>🛒Checkout - <%= typeof pageTitle !== 'undefined' ? pageTitle : 'Library' %></title>
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
<style>
body {
background-color: #f9f9f9;
font-family: "Segoe UI", sans-serif;
min-height: 100vh;
display: flex;
flex-direction: column;
}
main { flex: 1; }
.checkout-container {
background: white;
padding: 30px;
border-radius: 10px;
box-shadow: 0 3px 8px rgba(0,0,0,0.1);
margin-top: 30px;
margin-bottom: 30px;
}
.book-image {
width: 70px;
height: 100px;
object-fit: cover;
border-radius: 8px;
}
.price-summary {
border-top: 2px solid #ddd;
padding-top: 15px;
}

.btn-checkout {
background-color: #28a745;
color: white;
width: 100%;
font-weight: bold;
border: none;
border-radius: 6px;
padding: 12px;
transition: 0.3s;
}

.btn-checkout:hover {
background-color: #218838;
}

</style>
</head>

<body>

<nav class="navbar navbar-dark bg-dark px-3">
<div class="container-fluid">
<a class="navbar-brand" href="/">LIBRARY</a>
<a href="/books" class="btn btn-light btn-sm ms-auto">← Back to Books</a>
</div>
</nav>

<main class="container">

<div class="checkout-container">

<h2 class="mb-4">🛒 Checkout Summary</h2>

<% const validCart = Array.isArray(cart) ? cart : []; %>

<% if (validCart.length > 0) { %>

<div class="mb-3 text-end">
<button id="clearCartBtn" class="btn btn-outline-danger btn-sm">Clear Cart</button>
</div>

<table class="table table-hover table-striped align-middle">

<thead class="table-light">
<tr>
<th>Book</th>
<th>Title</th>
<th>Price (₹)</th>
<th>Quantity</th>
<th>Total (₹)</th>
<th>Remove</th>
</tr>
</thead>

<tbody>

<%
let subtotal = 0;

validCart.forEach(book => {

const price = book.price || 0;
const quantity = book.quantity || 1;
const total = price * quantity;

subtotal += total;
%>

<tr>

<td>
<img src="<%= book.cover_image || '/images/default-cover.png' %>" class="book-image">
</td>

<td><%= book.title || 'Untitled' %></td>

<td><%= price.toFixed(2) %></td>

<td><%= quantity %></td>

<td><%= total.toFixed(2) %></td>

<td>
<button
class="btn btn-sm btn-danger remove-btn"
data-id="<%= book.id %>">
Remove
</button>
</td>

</tr>

<% }); %>

</tbody>

</table>

<%
const tax = subtotal * 0.05;
const delivery = subtotal > 500 ? 0 : 50;
const grandTotal = subtotal + tax + delivery;
%>

<div class="row">

<div class="col-md-6 offset-md-6 price-summary">

<p><strong>Subtotal:</strong> ₹<%= subtotal.toFixed(2) %></p>

<p><strong>Tax (5%):</strong> ₹<%= tax.toFixed(2) %></p>

<p>
<strong>Delivery Charges:</strong>

<% if (delivery === 0) { %>
<span class="text-success">FREE</span>
<% } else { %>
₹<%= delivery.toFixed(2) %>
<% } %>

</p>

<h4 class="text-primary">
<strong>Grand Total:</strong> ₹<%= grandTotal.toFixed(2) %>
</h4>

</div>

</div>

<hr>

<h5>💳 Choose Payment Method:</h5>

<form action="/checkout/pay" method="POST" class="mt-3">

<div class="form-check">
<input class="form-check-input" type="radio" name="payment" value="cod" checked>
<label class="form-check-label">Cash on Delivery</label>
</div>

<div class="form-check">
<input class="form-check-input" type="radio" name="payment" value="upi">
<label class="form-check-label">UPI / Paytm / GPay</label>
</div>

<div class="form-check mb-4">
<input class="form-check-input" type="radio" name="payment" value="card">
<label class="form-check-label">Credit / Debit Card</label>
</div>

<button type="submit" class="btn-checkout">
Proceed to Pay ₹<%= grandTotal.toFixed(2) %>
</button>

</form>

<% } else { %>
<div class="alert alert-warning text-center">
Your cart is empty.
<a href="/books?showall=1">Browse books</a>
<% } %>

</div>

</main>
<div class="position-fixed top-0 end-0 p-3" style="z-index: 9999">
  <div id="liveToast" class="toast align-items-center text-bg-success border-0" role="alert">
    <div class="d-flex">
      <div class="toast-body" id="toastMsg">
        Message here
      </div>
      <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
    </div>
  </div>
</div>

<script>

function showToast(message, isError = false) {
  const toastEl = document.getElementById("liveToast");
  const toastMsg = document.getElementById("toastMsg");

  toastMsg.innerText = message;

  toastEl.classList.remove("text-bg-success", "text-bg-danger");
  toastEl.classList.add(isError ? "text-bg-danger" : "text-bg-success");

  const toast = new bootstrap.Toast(toastEl);
  toast.show();
}

document.addEventListener('DOMContentLoaded', () => {

const clearBtn = document.getElementById('clearCartBtn');

if(clearBtn){
clearBtn.addEventListener('click', async () => {

showToast("Clearing cart...");

await fetch('/cart/clear',{method:'POST'});

showToast("Cart cleared successfully");

location.reload();

});
}

document.querySelectorAll('.remove-btn').forEach(btn => {
btn.addEventListener('click', async () => {
const id = btn.dataset.id;

await fetch('/cart/remove',{
method:'POST',
headers:{'Content-Type':'application/json'},
body:JSON.stringify({id})
});

showToast("Item removed");

location.reload();

});
});

});

</script>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>