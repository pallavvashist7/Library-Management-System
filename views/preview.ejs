<!doctype html>
<html>
<head>
<meta charset="utf-8">
<title><%= pageTitle %></title>
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
<style>
#pdfContainer canvas { display:block; margin: 8px auto; border:1px solid #ddd; }
</style>
</head>
<body>
<nav class="navbar navbar-dark bg-dark">
<div class="container-fluid">
<a class="navbar-brand" href="/books">Library</a>
<div class="d-flex">
<% if (isLoggedIn) { %>
<span class="navbar-text text-white me-2">Hello, <%= username %></span>
<% } else { %>
<a class="btn btn-outline-light btn-sm" href="/signin">Login</a>
<% } %>
</div>
</div>
</nav>

<div class="container mt-4">
<h3><%= title %> — Preview</h3>
<p class="text-muted">Only the first 10 pages are shown in preview. Add to cart and purchase to view the full book.</p>

<div class="mb-3">
<button id="addCart" class="btn btn-success btn-sm">Add to Cart</button>
<a href="/checkout" class="btn btn-primary btn-sm ms-2">Proceed to Checkout</a>
<a href="/books" class="btn btn-secondary btn-sm ms-2">Back to Library</a>
</div>

<div id="pdfContainer"></div>
</div>

<div class="position-fixed top-0 end-0 p-3" style="z-index: 9999">
  <div id="liveToast" class="toast align-items-center text-bg-success border-0">
    <div class="d-flex">
      <div class="toast-body" id="toastMsg">Message</div>
      <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
    </div>
  </div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.8.162/pdf.min.js"></script>

<script>
function showToast(message, isError = false) {
  const toastEl = document.getElementById("liveToast");
  const toastMsg = document.getElementById("toastMsg");
  toastMsg.innerText = message;
  toastEl.classList.remove("text-bg-success", "text-bg-danger");
  toastEl.classList.add(isError ? "text-bg-danger" : "text-bg-success");
  const toast = new bootstrap.Toast(toastEl);
  toast.show();
}

const bookId = <%- JSON.stringify(bookId) %>;
const titleSafe = <%- JSON.stringify(title) %>;
const previewToken = <%- JSON.stringify(previewToken || '') %>;
const pdfUrl = `/read/${bookId}?t=${previewToken}`;
const pdfContainer = document.getElementById('pdfContainer');

(async function renderPreview(){
  try {
    const loadingTask = pdfjsLib.getDocument(pdfUrl);
    const pdf = await loadingTask.promise;
    const total = pdf.numPages;
    const pages = Math.min(10, total);
    for (let p=1; p<=pages; p++){
      const page = await pdf.getPage(p);
      const viewport = page.getViewport({ scale: 1.25 });
      const canvas = document.createElement('canvas');
      const ctx = canvas.getContext('2d');
      canvas.width = Math.floor(viewport.width);
      canvas.height = Math.floor(viewport.height);
      pdfContainer.appendChild(canvas);
      await page.render({ canvasContext: ctx, viewport }).promise;
    }
  } catch (err) {
    pdfContainer.innerHTML = '<div class="alert alert-danger">Failed to load preview.</div>';
    console.error(err);
  }
})();

document.getElementById('addCart').addEventListener('click', async () => {
  try {
    const res = await fetch('/cart/add', {
      method: 'POST',
      credentials: "include",
      headers: { 'Content-Type':'application/json'},
      body: JSON.stringify({ id: bookId, title: titleSafe })
    });

   if (res.ok) {
  const d = await res.json();
  showToast(titleSafe + " added to cart");
} else if (res.status === 401) {
  showToast('Please sign in to add to cart.', true);
  window.location.href = '/signin';
} else {
  showToast('Could not add to cart.', true);
}
  } catch (err) {
    console.error(err);
    showToast('Network error', true);
  }
});
</script>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>